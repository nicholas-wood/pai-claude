# Update footer per-run, preserving original run/paragraph structure
# Original footer1.xml runs (paragraph 0): "SOP", " ", "5", ".", "11", " – ", "Public Rescue Equipment", " Activation", "Page", " ", "1", "of", " ", "4"
# Original footer1.xml runs (paragraph 1): "Section ", "5", " – ", "Emergency", " Operations", "Effe", ...
RUN_REPLACEMENTS = {
    "5": "1",                                  # SOP version major AND Section number both go 5 -> 1
    "11": "4.1",                               # SOP version minor (5.11 -> 1.4.1)
    "Public Rescue Equipment": "Patrolling Areas",
    " Activation": "",                         # subsumed by "Patrolling Areas"
    "Emergency": "Patrol",
}
def replace_footer_text(footer_part):
    for para in footer_part.paragraphs:
        for run in para.runs:
            if run.text in RUN_REPLACEMENTS:
                run.text = RUN_REPLACEMENTS[run.text]

for section in doc.sections:
    for footer in [section.footer, section.first_page_footer, section.even_page_footer]:
        try:
            replace_footer_text(footer)
        except Exception:
            pass

def heading(text, style):
    p = doc.add_paragraph()
    if style:
        p.style = style
    _style_run(p.add_run(text))
    return p

def para(text=""):
    p = doc.add_paragraph()
    _style_body_para(p)
    if text:
        _style_run(p.add_run(text))
    return p

def rich(segments):
    p = doc.add_paragraph()
    _style_body_para(p)
    for text, fmt in segments:
        run = p.add_run(text)
        run.bold = fmt.get("bold", False)
        run.italic = fmt.get("italic", False)
        _style_run(run)
    return p

def bullet(text, level=0):
    p = doc.add_paragraph()
    if LIST_PARA:
        p.style = LIST_PARA
    p.paragraph_format.left_indent = Cm(0.6 + 0.6 * level)
    p.paragraph_format.space_after = BODY_SPACE_AFTER
    prefix = ["• ", "○ ", "▪ "][min(level, 2)]
    _style_run(p.add_run(prefix + text))
    return p

def bullet_rich(segments, level=0):
    p = doc.add_paragraph()
    if LIST_PARA:
        p.style = LIST_PARA
    p.paragraph_format.left_indent = Cm(0.6 + 0.6 * level)
    p.paragraph_format.space_after = BODY_SPACE_AFTER
    prefix = ["• ", "○ ", "▪ "][min(level, 2)]
    _style_run(p.add_run(prefix))
    for text, fmt in segments:
        run = p.add_run(text)
        run.bold = fmt.get("bold", False)
        run.italic = fmt.get("italic", False)
        _style_run(run)
    return p

def _style_cell(cell):
    """Apply Arial to every run in every paragraph of a table cell."""
    for p in cell.paragraphs:
        for run in p.runs:
            _style_run(run)

def make_table(headers, rows):
    tbl = doc.add_table(rows=1 + len(rows), cols=len(headers))
    if TABLE_STYLE:
        try:
            tbl.style = TABLE_STYLE
        except Exception:
            pass
    hdr = tbl.rows[0].cells
    for i, label in enumerate(headers):
        hdr[i].text = ""
        run = hdr[i].paragraphs[0].add_run(label)
        run.bold = True
        _style_run(run)
    for r, row_data in enumerate(rows, start=1):
        cells = tbl.rows[r].cells
        for c, val in enumerate(row_data):
            cells[c].text = val
            _style_cell(cells[c])
    return tbl

