"""Build SOP 1.4.1 Patrolling Areas .docx using SOP 5.11 as style template."""
from docx import Document
from docx.shared import Cm, Pt
from docx.oxml.ns import qn

BODY_FONT = "Arial"
BODY_SIZE = Pt(10)
BODY_SPACE_AFTER = Pt(6)

def _style_run(run):
    run.font.name = BODY_FONT
    run.font.size = BODY_SIZE
    # Set east-asia and cs fonts to Arial via rFonts to override docDefault Times New Roman
    rPr = run._element.get_or_add_rPr()
    rFonts = rPr.find(qn('w:rFonts'))
    if rFonts is None:
        from docx.oxml import OxmlElement
        rFonts = OxmlElement('w:rFonts')
        rPr.insert(0, rFonts)
    rFonts.set(qn('w:ascii'), BODY_FONT)
    rFonts.set(qn('w:hAnsi'), BODY_FONT)
    rFonts.set(qn('w:cs'), BODY_FONT)
    rFonts.set(qn('w:eastAsia'), BODY_FONT)
    return run

def _style_body_para(p):
    p.paragraph_format.space_after = BODY_SPACE_AFTER
    return p

