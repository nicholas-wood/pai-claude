#!/usr/bin/env python3
"""Extract .docx to clean markdown, preserving headings, bullets, and bold."""
import zipfile
import re
import sys
from xml.etree import ElementTree as ET

W = '{http://schemas.openxmlformats.org/wordprocessingml/2006/main}'

def get_run_text(r):
    rpr = r.find(f'{W}rPr')
    is_bold = rpr is not None and rpr.find(f'{W}b') is not None
    parts = []
    for child in r:
        tag = child.tag.split('}', 1)[-1]
        if tag == 't':
            parts.append(child.text or '')
        elif tag == 'tab':
            parts.append(' ')
        elif tag == 'br':
            parts.append('\n')
    text = ''.join(parts)
    if is_bold and text.strip():
        return f'**{text}**'
    return text

def extract(path):
    with zipfile.ZipFile(path) as z:
        xml = z.read('word/document.xml').decode('utf-8')
    root = ET.fromstring(xml)
    body = root.find(f'{W}body')

    output = []
    for p in body.iter(f'{W}p'):
        ppr = p.find(f'{W}pPr')
        style = None
        is_list = False
        if ppr is not None:
            pstyle = ppr.find(f'{W}pStyle')
            if pstyle is not None:
                style = pstyle.get(f'{W}val', '')
            if ppr.find(f'{W}numPr') is not None:
                is_list = True

        parts = []
        for r in p.findall(f'{W}r'):
            parts.append(get_run_text(r))
        text = ''.join(parts).strip()

        if not text:
            output.append('')
            continue

        if style and 'Heading1' in style:
            output.append(f'# {text}')
        elif style and 'Heading2' in style:
            output.append(f'## {text}')
        elif style and 'Heading3' in style:
            output.append(f'### {text}')
        elif is_list:
            output.append(f'- {text}')
        else:
            output.append(text)

    md = '\n\n'.join(output)
    md = re.sub(r'\*\*\*\*', '', md)
    md = re.sub(r'\*\*\s+\*\*', ' ', md)
    md = re.sub(r'\n{3,}', '\n\n', md)
    return md.strip()

if __name__ == '__main__':
    print(extract(sys.argv[1]))
