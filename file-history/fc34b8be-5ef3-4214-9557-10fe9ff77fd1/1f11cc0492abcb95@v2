# /home/nicholas-wood/.config/systemd/user/rclone-onedrive-lsv.service
[Unit]
# Live LSV OneDrive mount at ~/OneDrive-LSV so the box (and agents) can read
# Life Saving Victoria docs and write new ones, syncing to the LSV tenant.
# Requires fuse3 + an "onedrive-lsv" rclone remote configured via `rclone config`.
# Mirrors rclone-onedrive.service (personal account).
Description=rclone mount OneDrive LSV (~/OneDrive-LSV)
After=network-online.target
Wants=network-online.target

[Service]
Type=notify
ExecStartPre=/bin/mkdir -p %h/OneDrive-LSV
ExecStart=/usr/bin/rclone mount onedrive-lsv: %h/OneDrive-LSV \
  --vfs-cache-mode writes \
  --dir-cache-time 12h \
  --vfs-cache-max-age 24h
ExecStop=/bin/fusermount -u %h/OneDrive-LSV
Restart=on-failure
RestartSec=10
Environment=PATH=/usr/bin:/bin

[Install]
WantedBy=default.target
