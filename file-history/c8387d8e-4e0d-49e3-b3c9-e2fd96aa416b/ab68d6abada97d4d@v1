import * as Location from "expo-location";
import * as TaskManager from "expo-task-manager";
import * as SecureStore from "expo-secure-store";
import { api } from "./api";
import { shouldSuppressPing } from "./location-gate";

/**
 * Background location ping.
 *
 * Active only while member's availability is `available` OR they're on a callout
 * (FR-2.3 / FR-N-2.1). This module exposes start/stop functions called from the
 * availability toggle screen.
 *
 * Pings are POSTed to /v1/members/me/locations. The server is the authority on
 * "may this member ship a ping right now" — it returns 422 NOT_AVAILABLE for
 * unavailable members (FR-N-2.1). We still call `stopBackgroundLocation()` on
 * the client when toggling off (KICKOFF §6 rule 1) so we don't waste battery
 * or bother the user with the foreground-service notification, but the server
 * is the actual gate.
 *
 * ----------------------------------------------------------------------
 * Defence-in-depth client gate (FR-N-2.1 / KICKOFF §6 rule 1)
 * ----------------------------------------------------------------------
 *
 * `stopBackgroundLocation()` is called on transition to `unavailable` in
 * `app/(tabs)/index.tsx`. The Expo TaskManager can still fire one or
 * more queued / in-flight location callbacks after the stop call resolves
 * (deferredUpdatesInterval + OS scheduling), so a racing callback could
 * leak a ping after the user toggled off.
 *
 * The server is authoritative — it returns 422 NOT_AVAILABLE — but a
 * leaked ping still:
 *   1. burns battery and mobile data
 *   2. shows the foreground-service notification flicker
 *   3. emits a server-side rejected-ping log line that pollutes the
 *      availability audit trail
 *
 * So `sendPing` reads the persisted availability snapshot from SecureStore
 * before every POST and no-ops if it reads `unavailable`. The snapshot is
 * written by `setPersistedAvailability` from the availability screen
 * inside `applyAvailability` (single source of truth, written immediately
 * after the server confirms the transition).
 *
 * The persisted snapshot is NOT the source of truth for whether to start
 * the foreground service — `applyAvailability` makes that call. It's
 * strictly a defence-in-depth read inside the background task.
 */

const TASK_NAME = "loc-background-location";

/** SecureStore key holding the last server-confirmed availability snapshot. */
const AVAILABILITY_KEY = "loc_availability";

/**
 * Persist the latest server-confirmed availability state. Called from
 * `applyAvailability` after the PATCH succeeds, so the background task's
 * defensive read always sees the current truth.
 *
 * Write errors are swallowed (logged only) — the foreground UI state and
 * the server gate already protect the user; this is the third line of
 * defence, and a SecureStore write failure must not block the toggle.
 */
export async function setPersistedAvailability(value: "available" | "unavailable"): Promise<void> {
  try {
    await SecureStore.setItemAsync(AVAILABILITY_KEY, value, {
      keychainAccessible: SecureStore.WHEN_UNLOCKED,
    });
  } catch (err) {
    console.warn("failed to persist availability snapshot", (err as Error).message);
  }
}

/**
 * Read the persisted availability snapshot. Returns `null` if the key is
 * missing (e.g. before the user has ever toggled) or unreadable. The gate
 * in `sendPing` treats `null` as "don't block" so first-run behaviour is
 * not pessimised — the server still rejects pings for an unavailable
 * member regardless.
 */
export async function getPersistedAvailability(): Promise<"available" | "unavailable" | null> {
  try {
    const v = await SecureStore.getItemAsync(AVAILABILITY_KEY);
    if (v === "available" || v === "unavailable") return v;
    return null;
  } catch {
    return null;
  }
}

/**
 * Clear the persisted snapshot. Called on logout so a re-login doesn't
 * inherit the previous user's availability state. Wired from `auth.ts`
 * if/when that flow lands; safe to call eagerly.
 */
export async function clearPersistedAvailability(): Promise<void> {
  try {
    await SecureStore.deleteItemAsync(AVAILABILITY_KEY);
  } catch {
    // best-effort
  }
}

export async function ensureForegroundPermission(): Promise<boolean> {
  const { status } = await Location.requestForegroundPermissionsAsync();
  return status === "granted";
}

export async function ensureBackgroundPermission(): Promise<boolean> {
  const { status } = await Location.requestBackgroundPermissionsAsync();
  return status === "granted";
}

export async function startBackgroundLocation(): Promise<void> {
  const fg = await ensureForegroundPermission();
  if (!fg) throw new Error("Foreground location permission denied");
  const bg = await ensureBackgroundPermission();
  if (!bg) throw new Error("Background location permission denied");

  const already = await Location.hasStartedLocationUpdatesAsync(TASK_NAME).catch(() => false);
  if (already) return;

  await Location.startLocationUpdatesAsync(TASK_NAME, {
    accuracy: Location.Accuracy.Balanced,
    timeInterval: 60_000, // 60s baseline; tighter when on a callout (PR 16)
    distanceInterval: 50, // metres
    deferredUpdatesInterval: 30_000,
    foregroundService: {
      notificationTitle: "LifesaverOnCall",
      notificationBody: "On call — sharing location with dispatchers",
      notificationColor: "#4ea1ff",
    },
    pausesUpdatesAutomatically: false,
    showsBackgroundLocationIndicator: true,
  });
}

export async function stopBackgroundLocation(): Promise<void> {
  const started = await Location.hasStartedLocationUpdatesAsync(TASK_NAME).catch(() => false);
  if (started) {
    await Location.stopLocationUpdatesAsync(TASK_NAME);
  }
}

// Define the background task. When a position update arrives, ship it.
TaskManager.defineTask<{
  data: { locations: Location.LocationObject[] };
  error: TaskManager.TaskManagerError | null;
}>(TASK_NAME, async ({ data, error }) => {
  if (error || !data?.locations?.length) return;
  for (const loc of data.locations) {
    await sendPing(loc).catch((err) => {
      // Swallow — the background task must never crash; log to console only
      console.warn("location ping failed", (err as Error).message);
    });
  }
});

async function sendPing(loc: Location.LocationObject): Promise<void> {
  // FR-N-2.1 / KICKOFF §6 rule 1 — defence-in-depth gate. If the persisted
  // snapshot says the user is unavailable, no-op. Catches a racing
  // TaskManager callback fired between `stopBackgroundLocation()` and
  // the OS actually unscheduling the task. The server still rejects with
  // 422 NOT_AVAILABLE; this gate avoids the wasted round-trip and the
  // resulting audit-log noise.
  const persisted = await getPersistedAvailability();
  if (shouldSuppressPing(persisted)) return;

  // F10.1 — server stamps `recorded_at` itself; client-supplied timestamps
  // are ignored. We do NOT include `recorded_at` in the body.
  await api("/v1/members/me/locations", {
    method: "POST",
    body: {
      lat: loc.coords.latitude,
      lng: loc.coords.longitude,
      accuracy_m: loc.coords.accuracy ?? null,
      speed_mps: loc.coords.speed ?? null,
      heading_deg: loc.coords.heading ?? null,
      callout_id: null,
    },
  });
}
