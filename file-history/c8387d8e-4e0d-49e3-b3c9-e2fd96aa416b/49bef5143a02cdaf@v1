describe("CreateIncidentModal helpers", () => {
  it("exports the modal", () => {
    expect(typeof CreateIncidentModal).toBe("function");
  });

  it("computes Haversine distance with 1% accuracy on a known pair", () => {
    // Brighton Beach -> Williamstown is ~9.5 km in a straight line.
    const d = haversineMetres({ lat: -37.905, lng: 144.9888 }, { lat: -37.8625, lng: 144.9024 });
    expect(d).toBeGreaterThan(8_500);
    expect(d).toBeLessThan(11_000);
  });

  it("ranks bases by distance from a point", () => {
    const point = { lat: -37.905, lng: 144.9888 }; // Brighton
    const bases = [
      { id: "far", lat: -38.5408, lng: 143.9763 },
      { id: "near", lat: -37.8676, lng: 144.9783 }, // St Kilda
      { id: "mid", lat: -38.1413, lng: 145.1201 },
    ];
    const ranked = rankByDistance(point, bases);
    expect(ranked[0]!.id).toBe("near");
    expect(ranked[2]!.id).toBe("far");
  });
});

// === FR-6.1, FR-6.5, UC-3 — initial multi-target picker wiring ===
//
// Source-introspection (rather than jsdom rendering) for parity with the
// rest of the web-app test surface. The contract we lock here:
//   - the modal imports the new B01 add* helpers,
//   - it surfaces an "Initial page targets" expander,
//   - the follow-up POSTs use deterministic per-(callout, base/capability)
//     idempotency keys so a retry doesn't double-insert link rows,
//   - failures are non-blocking and surface via onCreated's warnings arg,
//   - the host PinController renders a passive WarningToast so the user
//     isn't blocked by a broken follow-up insert.

describe("CreateIncidentModal multi-target wiring", () => {
  it("imports the new B01 add* helpers", () => {
    expect(MODAL_SRC).toContain("addCalloutTargetBase");
    expect(MODAL_SRC).toContain("addCalloutRequiredCapability");
  });

  it("renders an 'Initial page targets' expander", () => {
    // Either label variant counts — opens or hides — both must be in the
    // source so the section is mounted and toggleable.
    expect(MODAL_SRC).toContain("Add initial page targets (optional)");
    expect(MODAL_SRC).toContain("Hide initial page targets");
    // The expander must also surface both pickers.
    expect(MODAL_SRC).toContain("Target bases");
    expect(MODAL_SRC).toContain("Required capabilities");
  });

  it("uses deterministic per-(callout, base/capability) idempotency keys", () => {
    expect(MODAL_SRC).toContain("`create-incident:${calloutId}:base:${baseId}`");
    expect(MODAL_SRC).toContain("`create-incident:${calloutId}:cap:${capabilityId}`");
  });

  it("collects warnings instead of failing the create on follow-up errors", () => {
    // The follow-up loop must be inside the same try block that catches
    // the create itself, but each link-insert wrapped in its own try
    // that pushes to `warnings` rather than rethrowing.
    expect(MODAL_SRC).toContain("warnings.push(");
    expect(MODAL_SRC).toContain("warnings.length > 0 ? warnings : undefined");
  });

  it("fires base inserts before capability inserts (sequential, predictable)", () => {
    const baseLoopIdx = MODAL_SRC.indexOf("for (const baseId of initialBaseIds)");
    const capLoopIdx = MODAL_SRC.indexOf("for (const capabilityId of initialCapabilityIds)");
    expect(baseLoopIdx).toBeGreaterThan(0);
    expect(capLoopIdx).toBeGreaterThan(baseLoopIdx);
  });

  it("PinController surfaces follow-up warnings via a passive toast", () => {
    expect(PIN_CONTROLLER_SRC).toContain("WarningToast");
    expect(PIN_CONTROLLER_SRC).toContain("createWarnings");
    // 8s auto-dismiss so the user isn't stuck looking at the warning.
    expect(PIN_CONTROLLER_SRC).toContain("8_000");
  });
});

// === B28 — severity dropped from create-incident modal ===
//
// Regression guard for UI_COVERAGE §7: the modal previously surfaced a
// severity 1-5 input that was silently appended to `comms_notes` as
// `Severity: N` text, an over-built field that lost fidelity on save.
// REQUIREMENTS.md does not reference severity, so the field is dropped
// entirely (rather than formalised as an `incident_severity` column —
// that's a product decision out of scope for B28). These tests assert
// the field is gone from both the rendered DOM-source and the submit
// payload, so a future PR re-introducing it without a real column will
// fail this suite. Source-introspection mirrors the rest of this file.
describe("CreateIncidentModal severity field removal (B28)", () => {
  // The module-level docstring legitimately references "severity"
  // (explaining why it was removed) so a naive file-wide grep is too
  // strict. Strip the leading block comment and search the remainder.
  const codeAfterDocstring = (() => {
    const firstClose = MODAL_SRC.indexOf("*/");
    return firstClose > 0 ? MODAL_SRC.slice(firstClose + 2) : MODAL_SRC;
  })();

  it("does not render any severity-labelled <Field> in the modal source", () => {
    // The previous incarnation rendered a numeric 1-5 picker behind a
    // `<Field label="Severity">` block. Any new surface attempting to
    // add it back via the same Field helper will trip this guard.
    expect(/<Field\s+label=["']Severity/i.test(codeAfterDocstring)).toBe(false);
  });

  it("does not declare a severity state hook or destructure the value into anything", () => {
    // Catches `useState<...>('low')` patterns, `severity` props,
    // `setSeverity`, etc. anywhere outside the explanatory docstring.
    expect(/\bsetSeverity\b/.test(codeAfterDocstring)).toBe(false);
    expect(/\bseverity\s*[:=]/.test(codeAfterDocstring)).toBe(false);
  });

  it("does not mention 'severity' anywhere in the submit payload construction", () => {
    // The pre-B28 submit handler shoved `Severity: ${severity}` into
    // `comms_notes`. We slice out the submit() body and assert the
    // string `severity` (case-insensitive) is absent from it. This is
    // tighter than the file-wide guard above because it specifically
    // protects the wire shape rather than just the rendered form.
    const submitStart = MODAL_SRC.indexOf("async function submit()");
    expect(submitStart).toBeGreaterThan(0);
    // Submit body runs from there to the closing `}` before `return (`.
    const submitEnd = MODAL_SRC.indexOf("return (", submitStart);
    expect(submitEnd).toBeGreaterThan(submitStart);
    const submitBody = MODAL_SRC.slice(submitStart, submitEnd);
    expect(/severity/i.test(submitBody)).toBe(false);
    // The remaining comms_notes call site interpolates only the
    // radio-channel free text (no severity-derived value).
    expect(submitBody).toContain("Radio channel:");
  });
});

