describe("triple-click counter", () => {
  it("does not fire on a single click", () => {
    const s = freshState();
    expect(evaluateClick(s, ll(1), 0, WINDOW_MS)).toBeNull();
    expect(s.count).toBe(1);
  });

  it("does not fire on a double click", () => {
    const s = freshState();
    expect(evaluateClick(s, ll(1), 0, WINDOW_MS)).toBeNull();
    expect(evaluateClick(s, ll(2), 100, WINDOW_MS)).toBeNull();
    expect(s.count).toBe(2);
  });

  it("fires on a triple click within the window", () => {
    const s = freshState();
    expect(evaluateClick(s, ll(1), 0, WINDOW_MS)).toBeNull();
    expect(evaluateClick(s, ll(2), 120, WINDOW_MS)).toBeNull();
    const fired = evaluateClick(s, ll(3), 240, WINDOW_MS);
    expect(fired).not.toBeNull();
    // Returns the latLng of the THIRD click — the post-zoom intent.
    expect(fired).toEqual(ll(3));
  });

  it("resets between separate runs and does not fire stale triples", () => {
    const s = freshState();
    evaluateClick(s, ll(1), 0, WINDOW_MS);
    // Second click well outside the window.
    expect(evaluateClick(s, ll(2), 5_000, WINDOW_MS)).toBeNull();
    // Third click also outside — fresh run, no triple.
    expect(evaluateClick(s, ll(3), 10_000, WINDOW_MS)).toBeNull();
  });

  it("requires the third click to land within windowMs of the first", () => {
    const s = freshState();
    evaluateClick(s, ll(1), 0, WINDOW_MS);
    evaluateClick(s, ll(2), 100, WINDOW_MS);
    // Third click after window expires — should NOT fire as a triple.
    const fired = evaluateClick(s, ll(3), WINDOW_MS + 50, WINDOW_MS);
    expect(fired).toBeNull();
  });

  it("can fire two triples in succession (state resets after firing)", () => {
    const s = freshState();
    evaluateClick(s, ll(1), 0, WINDOW_MS);
    evaluateClick(s, ll(2), 100, WINDOW_MS);
    expect(evaluateClick(s, ll(3), 200, WINDOW_MS)).toEqual(ll(3));
    // Second triple, fresh.
    evaluateClick(s, ll(4), 1_000, WINDOW_MS);
    evaluateClick(s, ll(5), 1_100, WINDOW_MS);
    expect(evaluateClick(s, ll(6), 1_200, WINDOW_MS)).toEqual(ll(6));
  });
});

/**
 * Helper: build a fake map + a fake clock + a fake timer scheduler so we
 * can drive `buildClickHandler` deterministically. The fake timer keeps a
 * list of scheduled callbacks and exposes `advance(ms)` to fire them in
 * order — this is enough for the disarm-on-timeout assertion.
 */
function makeHarness() {
  const setOptionsCalls: Array<{ disableDoubleClickZoom?: boolean }> = [];
  const map: ClickMap = {
    setOptions: (opts) => {
      setOptionsCalls.push(opts);
    },
  };
  let now = 0;
  type Pending = { fn: () => void; at: number; cancelled: boolean };
  const pending: Pending[] = [];
  const setTimer = (fn: () => void, ms: number): ReturnType<typeof setTimeout> => {
    const handle = { fn, at: now + ms, cancelled: false };
    pending.push(handle);
    // The handle's only role here is identity for clearTimer.
    return handle as unknown as ReturnType<typeof setTimeout>;
  };
  const clearTimer = (h: ReturnType<typeof setTimeout>) => {
    const handle = h as unknown as Pending;
    handle.cancelled = true;
  };
  const dropped: Array<{ lat: number; lng: number }> = [];
  const dropPin = (latLng: { lat: number; lng: number }) => {
    dropped.push(latLng);
  };
  const advance = (ms: number) => {
    now += ms;
    // Fire any non-cancelled timers whose time has come, in order.
    for (const p of pending.filter((p) => !p.cancelled && p.at <= now)) {
      p.cancelled = true; // one-shot
      p.fn();
    }
  };
  const click = (latLng: { lat: number; lng: number }, atMs?: number) => {
    if (typeof atMs === "number") now = atMs;
    handler.onClick(latLng);
  };
  const handler = buildClickHandler({
    map,
    dropPin,
    windowMs: WINDOW_MS,
    now: () => now,
    setTimer,
    clearTimer,
  });
  return { map, handler, setOptionsCalls, dropped, advance, click };
}

describe("PinDropMode dblclick-zoom suppression (Fix 2)", () => {
  it("disables dblclick-zoom on the very first click of a sequence", () => {
    const h = makeHarness();
    h.click({ lat: 1, lng: 1 }, 0);
    expect(h.setOptionsCalls.length).toBe(1);
    expect(h.setOptionsCalls[0]).toEqual({ disableDoubleClickZoom: true });
    expect(h.handler.isArmed()).toBe(true);
  });

  it("does NOT re-call setOptions on the 2nd click — once armed, stay armed", () => {
    const h = makeHarness();
    h.click({ lat: 1, lng: 1 }, 0);
    h.click({ lat: 1, lng: 1 }, 100);
    // Click 1 set true; click 2 must not re-set true (Google would
    // otherwise repeatedly receive the same option, which is harmless
    // but signals the arm/disarm logic isn't tracking state correctly).
    expect(h.setOptionsCalls.length).toBe(1);
    expect(h.handler.isArmed()).toBe(true);
  });

  it("restores dblclick-zoom AFTER the 3rd click drops the pin (so the next dblclick zooms)", () => {
    const h = makeHarness();
    h.click({ lat: 1, lng: 1 }, 0);
    h.click({ lat: 2, lng: 2 }, 100);
    h.click({ lat: 3, lng: 3 }, 200);
    // Pin dropped at the 3rd-click latLng (the post-zoom intent).
    expect(h.dropped).toEqual([{ lat: 3, lng: 3 }]);
    // Two setOptions calls: one to suppress, one to restore.
    expect(h.setOptionsCalls).toEqual([
      { disableDoubleClickZoom: true },
      { disableDoubleClickZoom: false },
    ]);
    expect(h.handler.isArmed()).toBe(false);
  });

  it("restores dblclick-zoom on idle timeout (no 3rd click within window)", () => {
    const h = makeHarness();
    h.click({ lat: 1, lng: 1 }, 0);
    expect(h.setOptionsCalls).toEqual([{ disableDoubleClickZoom: true }]);
    // Advance past the window — the disarm timer should fire.
    h.advance(WINDOW_MS + 1);
    expect(h.setOptionsCalls).toEqual([
      { disableDoubleClickZoom: true },
      { disableDoubleClickZoom: false },
    ]);
    expect(h.handler.isArmed()).toBe(false);
    expect(h.dropped).toEqual([]);
  });

  it("after a triple fires, the next single click re-arms (so a second triple suppresses zoom again)", () => {
    const h = makeHarness();
    h.click({ lat: 1, lng: 1 }, 0);
    h.click({ lat: 2, lng: 2 }, 100);
    h.click({ lat: 3, lng: 3 }, 200);
    // Triple #1 fired and disarmed.
    expect(h.setOptionsCalls).toEqual([
      { disableDoubleClickZoom: true },
      { disableDoubleClickZoom: false },
    ]);
    // Click 4 starts a new sequence — should re-arm.
    h.click({ lat: 4, lng: 4 }, 1_000);
    expect(h.setOptionsCalls).toEqual([
      { disableDoubleClickZoom: true },
      { disableDoubleClickZoom: false },
      { disableDoubleClickZoom: true },
    ]);
    expect(h.handler.isArmed()).toBe(true);
  });

  it("explicit disarm() (component unmount path) restores the option", () => {
    const h = makeHarness();
    h.click({ lat: 1, lng: 1 }, 0);
    expect(h.handler.isArmed()).toBe(true);
    h.handler.disarm();
    expect(h.handler.isArmed()).toBe(false);
    expect(h.setOptionsCalls).toEqual([
      { disableDoubleClickZoom: true },
      { disableDoubleClickZoom: false },
    ]);
  });

  it("disarm() is idempotent (no double-restore)", () => {
    const h = makeHarness();
    h.click({ lat: 1, lng: 1 }, 0);
    h.handler.disarm();
    h.handler.disarm();
    // Only one false call should be recorded — subsequent disarms do
    // nothing because `armed` is already false.
    expect(h.setOptionsCalls).toEqual([
      { disableDoubleClickZoom: true },
      { disableDoubleClickZoom: false },
    ]);
  });
});
