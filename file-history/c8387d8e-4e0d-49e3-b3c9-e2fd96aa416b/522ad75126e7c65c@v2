PROCESS:
1. cd ${built.worktreePath}
2. \`git push -u origin ${built.branch}\` — capture full output.
3. If push succeeds, construct the PR-create URL: https://github.com/nicholas-wood/lifesaveroncall/compare/dev...${built.branch}?expand=1 — return as prCreateUrl.
4. If push fails for any reason, return pushed:false and the exact error in message.

Do NOT attempt to install gh or use the GitHub API.`
}

// === Run ===

phase('Build')

const results = await pipeline(
  STREAMS,
  // Stage 1: BUILD
  (s) =>
    agent(buildPrompt(s), {
      phase: 'Build',
      schema: BUILD_SCHEMA,
      label: `build:${s.id}`,
    }),
  // Stage 2: REVIEW + up to 2 FIX iterations
  async (built, stream) => {
    if (!built) return { stream, status: 'BUILD_FAILED' }
    let current = built
    let lastReview = null
    for (let i = 0; i < 3; i++) {
      const review = await agent(reviewPrompt(stream, current), {
        phase: 'Review',
        schema: REVIEW_SCHEMA,
        label: `review:${stream.id}:r${i}`,
      })
      lastReview = review
      if (!review) return { stream, built: current, status: 'REVIEW_NULL' }
      if (review.verdict === 'PASS' || review.blockingIssues.length === 0) {
        return { stream, built: current, review, status: 'PASS' }
      }
      if (i === 2) {
        return { stream, built: current, review, status: 'CAP_HIT' }
      }
      const fixed = await agent(fixPrompt(stream, current, review, i + 1), {
        phase: 'Fix',
        schema: BUILD_SCHEMA,
        label: `fix:${stream.id}:r${i + 1}`,
      })
      if (!fixed) return { stream, built: current, review, status: 'FIX_NULL' }
      current = fixed
    }
    return { stream, built: current, review: lastReview, status: 'CAP_HIT' }
  },
  // Stage 3: FINAL REVIEW (PR description)
  async (prev, stream) => {
    if (!prev || !prev.built) return prev
    const final = await agent(finalPrompt(stream, prev.built), {
      phase: 'Final Review',
      schema: FINAL_SCHEMA,
      label: `final:${stream.id}`,
    })
    return { ...prev, final }
  },
)

// === Push ===

phase('Push & Summary')

const pushed = []
for (const r of results.filter(Boolean)) {
  if (!r || !r.built) {
    pushed.push({ stream: r?.stream, status: r?.status || 'UNKNOWN' })
    continue
  }
  const pushResult = await agent(pushPrompt(r.stream, r.built, r.final), {
    phase: 'Push & Summary',
    schema: PUSH_SCHEMA,
    label: `push:${r.stream.id}`,
  })
  pushed.push({
    streamId: r.stream.id,
    title: r.stream.title,
    branch: r.built.branch,
    status: r.status,
    push: pushResult,
    final: r.final,
    build: { commitCount: r.built.commitCount, summary: r.built.summary, knownLimitations: r.built.knownLimitations || [] },
    reviewVerdict: r.review?.verdict || 'NONE',
  })
}

log(`Workflow complete. ${pushed.filter((p) => p.push?.pushed).length}/${STREAMS.length} branches pushed.`)

return {
  summary: {
    streamsAttempted: STREAMS.length,
    streamsCompleted: pushed.filter((p) => p.push?.pushed).length,
    streamsFailed: pushed.filter((p) => !p.push?.pushed).length,
  },
  streams: pushed,
}
