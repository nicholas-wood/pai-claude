const BUILD_SCHEMA = {
  type: 'object',
  required: ['branch', 'worktreePath', 'commitCount', 'summary', 'commitMessage'],
  properties: {
    branch: { type: 'string' },
    worktreePath: { type: 'string' },
    commitCount: { type: 'number' },
    summary: { type: 'string', description: 'One-paragraph summary of what shipped' },
    commitMessage: { type: 'string', description: 'The HEAD commit message' },
    filesTouched: { type: 'array', items: { type: 'string' } },
    knownLimitations: { type: 'array', items: { type: 'string' } },
  },
  additionalProperties: false,
}

const REVIEW_SCHEMA = {
  type: 'object',
  required: ['verdict', 'blockingIssues', 'nonBlockingNotes'],
  properties: {
    verdict: { type: 'string', enum: ['PASS', 'NEEDS_FIX'] },
    blockingIssues: {
      type: 'array',
      items: {
        type: 'object',
        required: ['description', 'fileLine', 'suggestedFix'],
        properties: {
          description: { type: 'string' },
          fileLine: { type: 'string' },
          suggestedFix: { type: 'string' },
        },
        additionalProperties: false,
      },
    },
    nonBlockingNotes: { type: 'array', items: { type: 'string' } },
  },
  additionalProperties: false,
}

const FINAL_SCHEMA = {
  type: 'object',
  required: ['verdict', 'prTitle', 'prDescription'],
  properties: {
    verdict: { type: 'string', enum: ['APPROVE', 'APPROVE_WITH_NOTES', 'REJECT'] },
    prTitle: { type: 'string' },
    prDescription: { type: 'string', description: 'Markdown PR body: what, why, files, FR references, test notes, known limitations.' },
    notes: { type: 'array', items: { type: 'string' } },
  },
  additionalProperties: false,
}

const PUSH_SCHEMA = {
  type: 'object',
  required: ['branch', 'pushed', 'message'],
  properties: {
    branch: { type: 'string' },
    pushed: { type: 'boolean' },
    message: { type: 'string' },
    prCreateUrl: { type: 'string' },
  },
  additionalProperties: false,
}

function buildPrompt(s) {
  return `You are the BUILDER for stream "${s.id}" of a coordinated 12-stream parallel build of LifesaverOnCall.

WORKTREE (you own this; commit here, do not leave it):
  ${WT}/${s.id}
BRANCH (already created and checked out):
  ${s.branch}
BASE: forked from \`dev\` at tip 693cfc7.

STREAM TITLE: ${s.title}

WORK SPEC:
${s.spec}

REPO CONVENTIONS (binding):
- Bun runtime, TypeScript strict, no emojis, Australian English.
- Multi-tenant: AsyncLocalStorage + withTenantContextAsync. Every DB read filters by tenant. See packages/db/src/tenant-context.ts.
- Idempotency-Key header on every state-changing API write. Helper exists; reuse it.
- Hash-chained append-only incident log. Mutations blocked by Postgres trigger. Never modify, only append.
- KICKOFF.md §6 don't-do list is binding (PII, capability outages, location-while-unavailable, critical alerts).
- Server-side de-identification only; the client must never enforce the gate alone.
- No em dashes in user-facing copy.
- Match surrounding code style. Read 2-3 similar files before writing.

PROCESS:
1. cd into the worktree.
2. \`git status\` to confirm clean state on the branch.
3. Read the relevant spec docs (docs/REQUIREMENTS.md, docs/USE_CASES.md, docs/UI_COVERAGE.md, KICKOFF.md, EVENTS.md, SECURITY.md as needed for your stream).
4. Read the relevant source files in apps/ and packages/ to understand surrounding code.
5. Implement the work. Prefer small, focused commits over one mega-commit (e.g. one per FR or sub-feature).
6. Each commit: \`git add -A && git commit -m "<message>"\`. Commit messages: imperative mood, FR reference where applicable, one line subject + blank + body if needed.
7. Do NOT install dependencies. Do NOT run typecheck / lint / tests / docker / servers. The reviewer will catch what you can't compile-check.
8. If you discover the work is bigger than one pass can deliver well: ship a partial but coherent implementation with TODO comments at the genuine cut line, and describe the remaining work crisply in \`knownLimitations\`.
9. Stay inside your stream's scope. If you touch a file outside scope, that's a blocking issue at review.

Return BUILD_SCHEMA describing what you shipped.`
}

function reviewPrompt(s, built) {
  return `You are the REVIEWER for stream "${s.id}". An independent builder just shipped on branch ${built.branch}.

WORKTREE: ${built.worktreePath}
BUILDER'S SUMMARY: ${built.summary}
BUILDER'S KNOWN LIMITATIONS: ${(built.knownLimitations || []).join('; ') || 'none stated'}

PROCESS:
1. cd ${built.worktreePath}
2. \`git log --oneline dev..HEAD\` — see the commits.
3. \`git diff --stat dev..HEAD\` — see the file footprint.
4. \`git diff dev..HEAD\` — read the full diff. Focus on changed files in context.
5. Read the original spec for this stream:
${s.spec}
6. Cross-check against repo conventions (multi-tenant, idempotency, hash-chained log, KICKOFF §6, server-side de-id, no em dashes).

WHAT IS BLOCKING:
- Safety/correctness bugs (PII leaks, broken state machines, race conditions, security holes, location-while-unavailable, expired-award dispatch, critical-alert misuse).
- Missed FRs the spec required (cite FR-X).
- Code that obviously won't compile (TypeScript errors, missing imports, wrong types).
- Drift from KICKOFF.md don't-do list.
- Tenant-context not propagated on a new query.
- Mutation of incident_log_entries (must be append-only).
- Files modified outside the stream's scope without justification.
- Em dashes in user-facing copy.

WHAT IS NON-BLOCKING (note only):
- Style preferences, naming nits.
- Missing tests if the stream's spec didn't mandate them.
- Polish that would be nice but doesn't ship-block.
- Builder's own stated knownLimitations that match the spec's defer guidance.

Return PASS only when there are zero blocking issues. NEEDS_FIX with a precise blockingIssues list otherwise. Be specific: file:line, what's wrong, what to do.`
}

function fixPrompt(s, built, review, iter) {
  return `You are the FIXER for stream "${s.id}", iteration ${iter}. The reviewer flagged ${review.blockingIssues.length} blocking issue(s) on branch ${built.branch}.

WORKTREE: ${built.worktreePath}

BLOCKING ISSUES TO RESOLVE:
${review.blockingIssues.map((i, n) => `${n + 1}. ${i.description}\n   File/Line: ${i.fileLine}\n   Suggested fix: ${i.suggestedFix}`).join('\n\n')}

NON-BLOCKING NOTES (optional, address if quick):
${(review.nonBlockingNotes || []).map((n, i) => `${i + 1}. ${n}`).join('\n') || 'none'}

PROCESS:
1. cd ${built.worktreePath}
2. Address each blocking issue. Add NEW commits — do not amend or rebase the existing history.
3. Stay in scope. Same conventions as build (bun/TS strict, multi-tenant, idempotency, no em dashes).
4. Return updated BUILD_SCHEMA reflecting current state.`
}

function finalPrompt(s, built) {
  return `You are the FINAL REVIEWER for stream "${s.id}". The fix loop has completed; perform a lightweight final pass and write the PR description.

WORKTREE: ${built.worktreePath}
BRANCH: ${built.branch}

PROCESS:
1. cd ${built.worktreePath}
2. \`git log --oneline dev..HEAD\` and \`git diff --stat dev..HEAD\`.
3. Skim the diff one more time. Look for: obvious last-mile issues, missing imports, unused vars, anything that would embarrass on PR review.
4. Decide: APPROVE / APPROVE_WITH_NOTES / REJECT.
5. Write a PR description (Markdown) suitable for posting on GitHub:
   - **Title** (under 80 chars).
   - **What this changes** — bullets.
   - **Why** — link back to FR / UC / KICKOFF / redteam-finding references.
   - **Files touched** — list.
   - **Testing notes** — what to manually verify locally.
   - **Known limitations / follow-ups** — if any.
   - **Reviewer notes** — anything Nick should look at first.

Return FINAL_SCHEMA.`
}

